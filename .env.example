# AI — any OpenAI-compatible provider (see README for full list)
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
# Optional AI tuning (defaults shown). AI_MAX_COMPLETION_TOKENS=0 means no limit —
# recommended for reasoning models, which truncate (empty JSON) if the cap is too low.
AI_MAX_COMPLETION_TOKENS=0
AI_TEMPERATURE=0.1

TELEGRAM_BOT_TOKEN=your-bot-token-here
# Comma-separated list of chat IDs to receive notifications
TELEGRAM_CHAT_IDS=123456789

# Comma-separated full hours only — e.g. 08:00,20:00
SCHEDULE_HOURS=08:00
# Run once immediately on container start, then follow the schedule
RUN_ON_STARTUP=true
TZ=America/New_York

# Only change these if you rename the profile files
PROFILE_YAML_FILENAME=profile.yaml
PROFILE_CV_FILENAME=cv.txt
PROFILE_SCORING_PROMPT_FILENAME=scoring_prompt.txt
